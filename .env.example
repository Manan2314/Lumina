# =============================================================================
# Lumina Pathfinder — Environment Variables
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# Then fill in the real values from your Supabase project:
#   https://supabase.com/dashboard/project/<project-id>/settings/api
#
# For Vercel deployment, add each variable in:
#   Vercel Dashboard → Project → Settings → Environment Variables
#
# NEVER commit your real .env file — it is excluded in .gitignore.
# =============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────

# Your Supabase project URL
# Found at: Project Settings → API → Project URL
SUPABASE_URL="https://<project-ref>.supabase.co"

# Supabase anon/public key (safe to expose to the browser)
# Found at: Project Settings → API → Project API keys → anon public
SUPABASE_PUBLISHABLE_KEY="eyJ..."

# Supabase service role key (KEEP SECRET — server-side only)
# Found at: Project Settings → API → Project API keys → service_role
# This key bypasses Row Level Security — NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Vite public env vars (available in browser bundle via import.meta.env) ───
# These MUST duplicate the server-side values above.
# Only include the URL and anon key — never the service role key.

VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."

# ── Optional: Supabase project ID ─────────────────────────────────────────────
# Used by the Supabase CLI (supabase db push, supabase gen types, etc.)
SUPABASE_PROJECT_ID="<project-ref>"
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# ── Gemini AI (optional — enables personalised recommendation reasoning) ──────
# When set, Gemini generates a personalised 2-3 paragraph explanation for each
# recommendation. If unset or unreachable, the deterministic fallback is used
# automatically — the app works fully without this key.
#
# Get your API key from: https://aistudio.google.com/app/apikey
# Used server-side only — NEVER prefix with VITE_.
GEMINI_API_KEY=""
